# Copy this file to .env.local and fill in real values.
# This demo runs entirely on fake data. No env vars are required locally.

# Example: swap in a real database URL to persist accounts and audit logs
# DATABASE_URL=replace_with_your_database_url

# Example: plug in an LLM API key to replace the hardcoded AI recommendations
# OPENAI_API_KEY=replace_with_your_openai_key
# ANTHROPIC_API_KEY=replace_with_your_anthropic_key

# Example: NextAuth secret when adding role-based login
# NEXTAUTH_SECRET=replace_with_your_random_secret
# NEXTAUTH_URL=http://localhost:3000
